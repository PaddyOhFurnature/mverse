/target
**/*.rs.bk
*.pdb
.DS_Store

# Docs (curate locally before pushing)
docs/

# Archive and deploy (removed, kept locally only)
archive/
deploy/

# World data directories (per-identity storage)
world_data/
world_data_*/

# Terrain cache
elevation_cache/
*.tif
*.hgt

# Cache directories
.metaverse/cache/

# SSH/SCP targets
portable@*

# Debug/test files
*.log
debug_*
test_*

# Screenshots
screenshot/*.png
!screenshot/.gitkeep

# Built binaries (use scripts/build.sh to populate)
/bin/metaworld_alpha
/bin/metaverse-relay
/bin/metaverse-server
/bin/server.log
